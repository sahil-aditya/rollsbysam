{
  "schedule": "daily",
  "aggressive": true,
  "minSizeReductionPercentage": 10,
  "ignoredFiles": [
    "node_modules/*",
    ".github/workflows/*",
    "shop/*",
    "*.js",
    "*.html",
    "*.css",
    "*.json",
    "*.md",
    "*.mp3",
    "*.wav",
    "*.yml",
    "*.yaml",
    "package-lock.json",
    "package.json"
  ]
}
